# Copy this file to .env and fill in the real values — never commit .env

# Optional: Ghana NLP API for Twi/Ga/Ewe pronunciation
VITE_GHANA_NLP_KEY=your_key_here

# Firebase — get values from Firebase Console → Project Settings → Your apps
# Remember to add mediqgh.com to Firebase Console → Authentication → Authorized Domains
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
